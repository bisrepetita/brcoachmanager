rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Logo entreprise — admin uniquement en écriture, tout utilisateur connecté en lecture
    match /settings/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Tout le reste est bloqué
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
